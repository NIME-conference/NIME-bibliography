  pages = {33--36},
  booktitle = {Proceedings of the International Conference on New Interfaces for Musical Expression},
  editor = {Lia Mice and Nicole Robson and Tara Pattenden},
  year = {2026},
  month = {June},
  address = {London, United Kingdom},
  issn = {2220-4806},
  articleno = {9},
  track = {Music},
  note = {Installation},
  doi = {10.5281/zenodo.20782053},
  url = {http://nime.org/proceedings/2026/nime2026_music_9.pdf},
  presentation-video = {https://www.youtube.com/shorts/47uqooMMg14},
  abstract = {EyeLa is an accessible digital musical instrument (DMI) augmented reality (AR) app and rhythm game, designed for the musical engagement of children with multiple disabilities. It makes available head and eye movements as alternative input methods that are more intuitive and better aligned with natural body movements, empowering children with limited mobility to actively participate in music-making. EyeLa has also been made available as a rhythm game, lowering barriers to musical participation through game-based interaction that is accessible, motivating, and inclusive.},
  numpages = {4}
}

@inproceedings{nime2026_music_10,
  author = {Ruilei Duan and Zhengyang Ma},
  title = {The Discourse of an Instrument, and a Thousand Machines},
  pages = {37--40},
  booktitle = {Proceedings of the International Conference on New Interfaces for Musical Expression},
  editor = {Lia Mice and Nicole Robson and Tara Pattenden},
  year = {2026},
  month = {June},
  address = {London, United Kingdom},
  issn = {2220-4806},
  articleno = {10},
  track = {Music},
  note = {Live Performance},
  doi = {10.5281/zenodo.20782055},
  url = {http://nime.org/proceedings/2026/nime2026_music_10.pdf},
  presentation-video = {https://zmk5566.github.io/qianji/resource/xianyuqianji-hangzhou.mp3},
  abstract = {This paper introduces Qianji (literally meaning in Chinese “A Thousand Machines”), a web-based framework designed for massive distributed audio performance over audience members’ own cellular networks. When hundreds of smartphones must function as a synchronized speaker array in a single venue, the congestion and jitter inherent to high-density 4G/5G environments demand an architecture that prioritizes connection survival over bidirectional interactivity. Qianji addresses this with a “resilience-first” unidirectional design utilizing Server-Sent Events (SSE) and stateless HTTP clock synchronization, ensuring textural coherence even under severe network degradation. We validate this framework through two public performances of “The Discourse of an Instrument, and a Thousand Machines,” deploying up to 421 audience smartphones as a distributed resonance chamber for a traditional Guqin, with server-side stress tests confirming scalability to 2000+ concurrent connections. To manage the complexity of such an array, we present the “Video-to-Volume” workflow, which allows composers to treat the audience as pixels in a low-resolution display, mapping spatial gestures directly to sound without the overhead of real-time synthesis control. Grounded in the philosophy of cosmotechnics, this case study demonstrates how Qianji enables a new scale of acoustic intervention, reconciling the characteristic of the zither with the macro-granular digital presence of the crowd.},
  numpages = {4}
}

@inproceedings{nime2026_music_11,
